# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
venv/
.venv/
env/
.pytest_cache/

# --- Node / Frontend ---
node_modules/
dist/
build/
.next/
.cache/

# --- Environment / Secrets ---
.env
.env.local
.env.*.local

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# --- Data ---
# Ignore raw corpora (large, often not redistributable).
# `.gitkeep` is re-included so the folder still exists in git.
/data/raw/*
!/data/raw/.gitkeep
/data/processed/*
!/data/processed/.gitkeep
